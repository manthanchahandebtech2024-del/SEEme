# SEEme Configuration
# Copy this to server/.env and fill in your values

# Database (SQLite - works out of the box)
DATABASE_URL="file:./seeme.db"

# Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY=7d

# AI Providers (optional - falls back to local scoring if not set)
# Set AI_PROVIDER to: azure, openai, gemini, or local
AI_PROVIDER=local

# Azure OpenAI (recommended for enterprise)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2023-05-15

# OpenAI (direct)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Rate Limiting
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
